# Copy to ops/.env for local-without-pm2 runs.
# When running via pm2 the values in ecosystem.config.js take precedence.

OPS_SERVICE_NAME=dev
OPS_LOG_LEVEL=INFO

# SQLite path is relative to the process CWD. Absolute paths on POSIX use
# four slashes: sqlite+aiosqlite:////abs/path/ops.db
OPS_DATABASE_URL=sqlite+aiosqlite:///./ops.db

OPS_REDIS_URL=redis://localhost:6379/0

OPS_DASHBOARD_API_HOST=0.0.0.0
OPS_DASHBOARD_API_PORT=8000

OPS_EXPORTER_HOST=0.0.0.0
OPS_EXPORTER_PORT=9108

# Set before starting dashboard-api in any non-dev deployment.
OPS_DASHBOARD_PASSWORD=change-me
